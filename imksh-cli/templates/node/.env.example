# ==========================
# Application
# ==========================
NODE_ENV=development
PORT=5001

APP_NAME=My App
APP_URL=http://localhost:5173
APP_EMAIL=noreply@example.com
APP_PRIMARY_COLOR=#2563eb

# ==========================
# Database
# ==========================
MONGO_URI=

# ==========================
# JWT
# ==========================
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ==========================
# Cloudinary
# ==========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================
# Email (SMTP)
# ==========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="My App <noreply@example.com>"

# ==========================
# CORS
# ==========================
CLIENT_URL=http://localhost:5173

# ==========================
# Cookie
# ==========================
COOKIE_NAME=token
COOKIE_EXPIRES_IN=7d

# ==========================
# Rate Limiting
# ==========================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ==========================
# Rate Limiting
# ==========================
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:noreply@example.com